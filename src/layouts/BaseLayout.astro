---
import '../styles/global.css';
import TokenManager from '../components/TokenManager';
import RequestHistoryDrawer from '../components/RequestHistoryDrawer';
import ToastHost from '../components/ToastHost';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'MoMA API Playground',
  description = 'Interactive documentation for the Museum of Modern Art Collection API',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen bg-white text-black font-sans antialiased">
    <!-- Header -->
    <header class="border-b-2 border-black bg-white sticky top-0 z-30">
      <div class="max-w-[1400px] mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 hover:opacity-70 transition-opacity">
          <div class="w-10 h-10 bg-black flex items-center justify-center text-white font-bold text-xl">
            M
          </div>
          <div>
            <h1 class="text-xl font-medium">MoMA API</h1>
            <p class="text-xs text-gray-600">Interactive Documentation</p>
          </div>
        </a>

        <div class="flex items-center gap-3">
          <RequestHistoryDrawer client:load />
          <TokenManager client:load />
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="min-h-[calc(100vh-120px)]">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-gray-200 bg-gray-50">
      <div class="max-w-7xl mx-auto px-6 py-8">
        <div class="flex flex-col md:flex-row justify-between items-center gap-4">
          <div class="text-sm text-gray-600">
            <p>Powered by the <strong>Museum of Modern Art Collection API</strong></p>
            <p class="text-xs mt-1">Unofficial documentation playground — Not affiliated with MoMA</p>
          </div>
          <div class="flex items-center gap-4 text-sm">
            <a href="https://api.moma.org" target="_blank" rel="noopener" class="text-gray-600 hover:text-black">
              API Documentation
            </a>
            <span class="text-gray-300">|</span>
            <a href="https://www.moma.org" target="_blank" rel="noopener" class="text-gray-600 hover:text-black">
              MoMA.org
            </a>
          </div>
        </div>
      </div>
    </footer>
    <ToastHost client:load />
  </body>
</html>
